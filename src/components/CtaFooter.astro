---
import type { Dict } from '../i18n';

interface Props {
  dict: Dict;
}
const { dict } = Astro.props;
const mailHref = `mailto:ketimoro@gmail.com?subject=${encodeURIComponent(dict.cta.mailSubject)}`;
---

<section class="relative overflow-hidden px-6 py-40 text-center">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(700px 420px at 50% 100%, rgb(34 211 238 / 0.12), transparent 70%)"
    aria-hidden="true"
  >
  </div>
  <h2 class="reveal relative font-display text-5xl font-extrabold tracking-tight text-bright text-balance lg:text-7xl">
    {dict.cta.title}
  </h2>
  <p class="reveal relative mt-6 text-xl">{dict.cta.sub}</p>
  <a
    href={mailHref}
    class="reveal relative mt-10 inline-flex rounded-full bg-accent px-8 py-4 text-base font-semibold text-ink transition-shadow hover:shadow-[0_0_40px_rgb(34_211_238/0.5)]"
  >
    {dict.cta.button}
  </a>
</section>

<footer class="border-t border-line/60 px-6 py-10 text-center font-mono text-xs text-body/70">
  {dict.cta.copyright}
</footer>
