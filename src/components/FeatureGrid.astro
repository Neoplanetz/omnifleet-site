---
import type { Dict } from '../i18n';

interface Props {
  dict: Dict;
}
const { dict } = Astro.props;

// Lucide-style 24x24 stroke paths, order-matched to dict.grid.items.
const ICONS = [
  'M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z M12 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6',
  'M9 2h6a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2 M9 14l2 2 4-4',
  'M8 6h13 M8 12h13 M8 18h13 M3 6h.01 M3 12h.01 M3 18h.01',
  'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8 M22 21v-2a4 4 0 0 0-3-3.87',
  'M5 8l6 6 M4 14l6-6 2-3 M2 5h12 M7 2h1 M22 22l-5-10-5 10 M14 18h6',
  'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M12 17h.01',
];
if (ICONS.length !== dict.grid.items.length) throw new Error('FeatureGrid: ICONS must match dict.grid.items length');
const items = dict.grid.items.map((item, i) => ({ ...item, icon: ICONS[i] }));
---

<section class="mx-auto max-w-6xl px-6 py-32">
  <p class="reveal font-mono text-xs tracking-[0.3em] text-accent uppercase">{dict.grid.eyebrow}</p>
  <h2 class="reveal mt-4 max-w-2xl font-display text-4xl font-bold text-bright text-balance lg:text-5xl">
    {dict.grid.title}
  </h2>
  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => (
      <div class="reveal rounded-xl border border-line bg-panel/50 p-6 transition-colors hover:border-accent/40">
        <svg
          class="h-6 w-6 text-accent"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d={item.icon} />
        </svg>
        <h3 class="mt-4 text-lg font-semibold text-bright">{item.title}</h3>
        <p class="mt-2 text-sm leading-relaxed">{item.body}</p>
      </div>
    ))}
  </div>
</section>
