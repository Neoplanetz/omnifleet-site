---
import type { Dict } from '../i18n';

interface Props {
  dict: Dict;
}
const { dict } = Astro.props;
---

<section class="border-y border-line/60 bg-panel/40">
  <div class="mx-auto grid max-w-6xl grid-cols-2 lg:grid-cols-4">
    {dict.stats.map((stat) => (
      <div class="reveal flex flex-col items-center gap-2 px-6 py-14 text-center">
        <span class="font-display text-5xl font-extrabold text-bright tabular-nums lg:text-6xl">{stat.value}</span>
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
