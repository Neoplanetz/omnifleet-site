---
import '../styles/global.css';
import type { Dict } from '../i18n';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  locale: 'ko' | 'en';
  dict: Dict;
}
const { locale, dict } = Astro.props;
const site = (Astro.site?.href ?? 'https://omnifleet-site.pages.dev/').replace(/\/$/, '');
const path = locale === 'en' ? '/en/' : '/';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{dict.meta.title}</title>
    <meta name="description" content={dict.meta.description} />
    <link rel="canonical" href={site + path} />
    <link rel="alternate" hreflang="ko" href={site + '/'} />
    <link rel="alternate" hreflang="en" href={site + '/en/'} />
    <link rel="alternate" hreflang="x-default" href={site + '/'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0c10" />
    <meta property="og:title" content={dict.meta.title} />
    <meta property="og:description" content={dict.meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site + path} />
    <meta property="og:image" content={site + '/posters/hero.jpg'} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Preload hero poster so LCP image is fetched early -->
    <link rel="preload" as="image" href="/posters/hero.jpg" fetchpriority="high" />
    <noscript><style>.reveal{opacity:1;transform:none}</style></noscript>
  </head>
  <body class="bg-ink font-sans text-body antialiased">
    <SiteHeader locale={locale} dict={dict} />
    <main><slot /></main>
    <footer class="border-t border-line/60 px-6 py-10 text-center font-mono text-xs text-body/80">{dict.cta.copyright}</footer>
    <script>
      // Scroll reveal: one observer for all .reveal elements.
      const revealObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.2 }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      // Managed videos: play only while on screen; never autoplay under reduced motion.
      // Authoring contract: every <video data-managed> MUST set muted + playsinline +
      // poster (+ preload="metadata" or "none"), and MUST NOT set the autoplay
      // attribute — this observer owns playback, and autoplay would start frames
      // before the reduced-motion pause lands (breaking the poster guarantee).
      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)');
      let reduced = reducedMotion.matches;
      reducedMotion.addEventListener('change', () => {
        reduced = reducedMotion.matches;
        if (reduced) document.querySelectorAll<HTMLVideoElement>('video[data-managed]').forEach((v) => v.pause());
      });
      const videoObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const video = entry.target as HTMLVideoElement;
            if (reduced) {
              video.pause();
              continue;
            }
            if (entry.isIntersecting) video.play().catch(() => {});
            else video.pause();
          }
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('video[data-managed]').forEach((v) => videoObserver.observe(v));
    </script>
  </body>
</html>
